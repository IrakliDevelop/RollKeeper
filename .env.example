# Upstash Redis (required for campaign sync)
# For local dev with docker-compose: use http://localhost:8079 and local_dev_token
# For production: get these from the Upstash dashboard
UPSTASH_REDIS_REST_URL=http://localhost:8079
UPSTASH_REDIS_REST_TOKEN=local_dev_token

# AWS S3 (for avatar uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-central-1
S3_BUCKET_NAME=rollkeeper-images
